    "ai.abstraction.LightRush",
    "ai.abstraction.HeavyRush"
  ],
  "llm_interval": 1,
  "resource_advantage_alpha": 2.0,
  "resource_advantage_weights": {
    "base": 10.0,
    "worker": 1.0,
    "light": 2.0,
    "heavy": 2.0,
    "ranged": 2.0,
    "resource": 1.0
  },
  "surrogate_version": "policy",
  "surrogate_mode": "all_avg", 
  "surrogate_recent_match_window": 10,
  "surrogate_round_samples_per_match": 10,
  "surrogate_log_dir": "logs/microrts"
