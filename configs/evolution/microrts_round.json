{
  "algorithm": "nsga2",
  "evaluator": "gameplay",
  "population_size": 20,
  "num_generations": 50,
  "convergence_generations": 10,
  "reproduction_operator_probs": {
    "crossover": 0.2,
    "mutation": 0.5,
    "reflection": 0.3
  },
  "enable_reflection_operator": true,
  "reflection_max_components_to_rewrite": 1,
  "strategy_mutation": {
    "pool_replacement": 0.2,
    "identity_preserving_rewrite": 0.6,
    "identity_shift_rewrite": 0.1,
    "bitmask_flip": 0.1
  },
  "selection_method": "random",
  "tournament_size": 3,
  "crossover": "uniform",
  "crossover_repair_enabled": true,
  "environment_selection_method": "elitism",
  "final_test_max_front": 0,
  "include_strategy_identity_in_prompt": false,
  "evolving_prompt_components": [],
  "non_evolving_prompt_components": [
    "role",
    "critical_rules",
    "game_objects",
    "actions",
    "raw_move_format",
    "example_safety_rule",
    "state_interpretation_step",
    "decision_logic",
    "decision_process",
    "consistency_rule",
    "attack_style",
    "barracks_ownership_rule",
    "start_game_rule",
    "stable_worker_role_rule",
    "memoryless_barracks_rule",
    "field_requirements",
    "json_schema",
    "current_game_state_marker",
    "training_examples"
  ],
  "component_pool_path": "eagle/prompts/components.json",
  "initial_population_seeds": [],
  "gameplay_rate": 1.0,
  "objective_config": {
    "mode": "multi",
    "objectives": [
      "resource_advantage",
      "win_score"
    ]
  },
  "gameplay_opponents": [],
  "gameplay_map_dir": "8x8",
  "llm_interval": [1],
  "save_trace_on_test": false,
  "resource_advantage_alpha": 2.0,
  "win_bonus": 100.0,
  "resource_advantage_weights": {
    "base": 10.0,
    "worker": 1.0,
    "light": 2.0,
    "heavy": 2.0,
    "ranged": 2.0,
    "resource": 1.0
  },
  "prompt_history_path": "logs/microrts/round_evol/history.jsonl",
  "one_eval_rounds": 8,
  "round_eval_parallel_workers": 8,
  "agent_eval_parallel_workers": 8,
  "individual_eval_parallel_workers": 8,
  "llm_parallel_workers": 8,
  "surrogate_version": "eaglePolicy",
  "surrogate": "round",
  "surrogate_recent_match_window": 10,
  "surrogate_round_samples_per_match": 1,
  "surrogate_log_dir": "logs/microrts",
  "round_eval_model": "llama3.1:8b",
  "round_state_seed": 0
}

