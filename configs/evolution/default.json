{
  "algorithm": "nsga2",
  "evaluator": "gameplay",
  "population_size": 10,
  "num_generations": 50,
  "convergence_generations": 10,
  "reproduction_operator_probs": {
    "crossover": 0.7,
    "mutation": 0.2,
    "reflection": 0.1
  },
  "example_reproduction_operator_probs": {
    "crossover": 0.5,
    "mutation": 0.5
  },
  "example_mutation_source_probs": {
    "fresh": 0.5,
    "pool": 0.5
  },
  "enable_reflection_operator": true,
  "reflection_max_components_to_rewrite": 1,
  "strategy_mutation": {
    "pool_replacement": 0.4,
    "identity_preserving_rewrite": 0.35,
    "identity_shift_rewrite": 0.25,
    "bitmask_flip": 0.0
  },
  "mutation_selection_mode": "fixed",
  "mutation_operator": "mix",
  "selection_method": "random",
  "tournament_size": 3,
  "crossover": "uniform",
  "crossover_operator": "uniform",
  "crossover_repair_enabled": true,
  "environment_selection_method": "elitism",
  "final_test_max_front": 1,
  "include_strategy_identity_in_prompt": false,
  "evolving_prompt_components": [
    "role",
    "game_rules",
    "unit_types",
    "building_types",
    "game_state_format"
  ],
  "non_evolving_prompt_components": [
    "role",
    "critical_rules",
    "game_objects",
    "actions",
    "raw_move_format",
    "example_safety_rule",
    "state_interpretation_step",
    "decision_logic",
    "decision_process",
    "consistency_rule",
    "attack_style",
    "barracks_ownership_rule",
    "start_game_rule",
    "stable_worker_role_rule",
    "memoryless_barracks_rule",
    "field_requirements",
    "json_schema",
    "current_game_state_marker",
    "training_examples"
  ],
  "component_pool_path": "eagle/prompts/components.json",
  "initial_population_seeds": [],
  "tick_limit": 5000,
  "llm_call_limit": 50,
  "fitness_metric": "default",
  "agent_class": "ai.eagle.EAGLE",
  "llm_model": "local",
  "llm_base_url": "http://127.0.0.1:8080/v1",
  "gameplay_rate": 0.25,
  "gameplay_refresh_interval": 5,
  "surrogate_top_ratio": 0.3,
  "archive_parent_ratio": 0.25,
  "min_token_length": 1,
  "objective_config": {
    "mode": "multi",
    "objectives": [
      "resource_advantage",
      "win_score"
    ]
  },
  "aggressiveness_objective_enabled": false,
  "aggressiveness_mode": "hybrid",
  "aggressiveness_llm_weight": 0.3,
  "aggressiveness_component_weight": 0.7,
  "aggressiveness_judge_model": "local",
  "aggressiveness_judge_temperature": 0.0,
  "training_example_sample_count": "random_0_4",
  "training_example_fixed_count": false,
  "use_few_shot_examples": true,
  "min_examples": 0,
  "max_examples": 3,
  "gameplay_opponents": [
    "ai.abstraction.LightRush",
    "ai.abstraction.HeavyRush"
  ],
  "gameplay_map_dir": "8x8",
   "llm_interval": [10, 10, 5, 3, 1],
 
  "save_trace_on_test": false,
  "resource_advantage_alpha": 2.0,
  "win_bonus": 100.0,
  "resource_advantage_weights": {
    "base": 10.0,
    "worker": 1.0,
    "light": 2.0,
    "heavy": 2.0,
    "ranged": 2.0,
    "resource": 1.0
  },
  "surrogate_version": "eaglePolicy",
  "surrogate": "round",
  "surrogate_recent_match_window": 10,
  "surrogate_round_samples_per_match": 10,
  "round_eval_model": "local",
  "round_state_seed": null,
  "surrogate_log_dir": "logs/microrts",
  "prompt_history_path": "logs/microrts/round_evol/history.jsonl",
  "one_eval_rounds": 8
}

