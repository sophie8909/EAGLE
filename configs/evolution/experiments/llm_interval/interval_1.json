{
  "algorithm": "steady_state_nsga2",
  "population_size": 10,
  "num_generations": 100,
  "convergence_generations": 100,
  "reproduction_operator_probs": {
    "crossover": 0.45,
    "mutation": 0.45,
    "reflection": 0.1
  },
  "enable_reflection_operator": true,
  "reflection_max_components_to_rewrite": 1,
  "strategy_mutation": {
    "pool_replacement": 0.4,
    "identity_preserving_rewrite": 0.35,
    "identity_shift_rewrite": 0.25
  },
  "selection_method": "random",
  "tournament_size": 3,
  "crossover": "uniform",
  "crossover_repair_enabled": true,
  "environment_selection_method": "elitism",
  "steady_state_surrogate_offspring_count": 8,
  "final_test_max_front": 1,
  "include_strategy_identity_in_prompt": false,
  "evolving_prompt_components": [
    "role",
    "game_rules",
    "unit_types",
    "building_types",
    "game_state_format"
