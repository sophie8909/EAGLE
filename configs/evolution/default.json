{
  "algorithm": "nsga2",
  "population_size": 10,
  "num_generations": 50,
  "convergence_generations": 10,
  "reproduction_operator_probs": {
    "crossover": 0.7,
    "mutation": 0.2,
    "reflection": 0.1
  },
  "enable_reflection_operator": true,
  "reflection_max_components_to_rewrite": 1,
  "strategy_mutation": {
    "pool_replacement": 0.4,
    "identity_preserving_rewrite": 0.35,
    "identity_shift_rewrite": 0.25,
    "bitmask_flip": 0.0
  },
  "selection_method": "random",
  "tournament_size": 3,
  "crossover": "uniform",
  "crossover_repair_enabled": true,
  "environment_selection_method": "elitism",
  "steady_state_surrogate_offspring_count": 4,
  "final_test_max_front": 1,
  "include_strategy_identity_in_prompt": false,
  "evolving_prompt_components": [
    "role",
    "game_rules",
    "unit_types",
    "building_types",
    "game_state_format"
  ],
  "non_evolving_prompt_components": [
    "role",
    "critical_rules",
    "game_objects",
    "actions",
    "raw_move_format",
    "example_safety_rule",
    "state_interpretation_step",
    "decision_logic",
    "decision_process",
    "consistency_rule",
    "attack_style",
    "barracks_ownership_rule",
    "start_game_rule",
    "stable_worker_role_rule",
    "memoryless_barracks_rule",
    "field_requirements",
    "json_schema",
    "current_game_state_marker",
    "training_example_no_workers",
    "training_example_worker_bootstrap",
    "training_example_build_barracks",
    "training_example_repeat_barracks_low_resources",
    "training_example_enemy_barracks_not_ally",
    "training_example_many_workers_no_train_worker",
    "training_example_ally_barracks_train_army"
  ],
  "component_pool_path": "eagle/prompts/components.json",
  "initial_population_seeds": [],
  "run_time_per_game_sec": 500,
  "real_eval_rate": 0.25,
  "real_eval_opponents": [
    "ai.abstraction.LightRush",
    "ai.abstraction.HeavyRush"
  ],
   "llm_interval": [10, 10, 5, 3, 1],
 
  "save_trace_on_test": false,
  "resource_advantage_alpha": 2.0,
  "win_bonus": 100.0,
  "resource_advantage_weights": {
    "base": 10.0,
    "worker": 1.0,
    "light": 2.0,
    "heavy": 2.0,
    "ranged": 2.0,
    "resource": 1.0
  },
  "surrogate_version": "policy",
  "surrogate_mode": "light_rush_and_heavy_rush", 
  "surrogate_recent_match_window": 10,
  "surrogate_round_samples_per_match": 10,
  "surrogate_log_dir": "logs/microrts",
  "prompt_history_path": "./eagle_round_evol/history.jsonl",
  "one_eval_rounds": 5
}
