from openai import OpenAI

client = OpenAI(
    base_url="http://127.0.0.1:8080/v1",
    api_key="dummy",
)

resp = client.chat.completions.create(
    model="local",
    messages=[
        {"role": "user", "content": "Return only this JSON: {\"ok\": true}"}
    ],
    temperature=0.1,
    max_tokens=64,
)

print(resp.choices[0].message.content)