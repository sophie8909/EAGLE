{
  "metadata": {
    "identity_component_key": "strategy_identity",
    "non_evolving_component_keys": [
      "json_schema",
      "critical_rules",
      "state_interpretation",
      "consistency_rules",
      "worker_role_rule"
    ]
  },

  "role": [
    [
      "You are an AI playing a deterministic real-time strategy game.",
      "You control Ally units only.",
      "Use only CURRENT GAME STATE. Do not use memory."
    ]
  ],

  "critical_rules": [
    [
      "Only control Ally units.",
      "Each unit gets at most one action.",
      "Do not trust current_action=\"idling\".",
      "Use Feature locations order for stable assignment.",
      "Do NOT use examples as current state.",
      "Enemy Barracks does NOT count as Ally Barracks."
    ]
  ],

  "state_interpretation": [
    [
      "STATE INTERPRETATION:",
      "worker_count = number of lines containing 'Ally Worker Unit'",
      "worker_status = less_than_2 if worker_count is 0 or 1",
      "worker_status = enough_workers if worker_count is 2 or more",
      "has_ally_barracks = True only if 'Ally Barracks Unit' exists",
      "worker_1 = first Ally Worker in Feature locations",
      "worker_2 = second Ally Worker in Feature locations",
      "worker_3+ = remaining workers"
    ]
  ],

  "worker_role_rule": [
    [
      "STABLE ROLE ASSIGNMENT:",
      "worker_1 = always harvest",
      "worker_2 = always build barracks (until exists)",
      "worker_3+ = harvest",
      "Do NOT swap roles.",
      "Do NOT reassign based on idling.",
      "worker_2 must always be builder."
    ]
  ],

  "decision_logic": [
    [
      "DECISION:",
      "If worker_status=less_than_2 -> train_worker",
      "If worker_status=enough_workers AND has_ally_barracks=False -> build_barracks_with_worker_2",
      "If has_ally_barracks=True -> train_army_or_attack"
    ]
  ],

  "consistency_rules": [
    [
      "CONSISTENCY:",
      "If worker_count >= 2, do NOT choose train_worker because of worker count.",
      "If has_ally_barracks=False, must build barracks.",
      "If has_ally_barracks=True, do NOT build barracks.",
      "If worker_2 exists, builder must be worker_2."
    ]
  ],

  "strategy": [
    [
      "STRATEGY:",
      "1. Get at least 2 workers",
      "2. Build barracks using worker_2",
      "3. Produce army",
      "4. Attack enemy"
    ]
  ],

  "strategy_action_mapping": [
    [
      "ACTION MAPPING:",
      "train_worker -> base train(worker)",
      "build_barracks -> worker_2 build",
      "economy -> harvest",
      "army -> barracks train",
      "attack -> attack enemy"
    ]
  ],

  "decision_process": [
    [
      "PROCESS:",
      "1. Parse state",
      "2. Assign worker roles by order",
      "3. Apply decision rules",
      "4. Generate actions"
    ]
  ],

  "json_schema": [
    [
      "{",
      "  \"thinking\": \"worker_count=<n>; worker_status=<...>; has_ally_barracks=<...>; decision=<...>\",",
      "  \"moves\": []",
      "}"
    ]
  ],

  "valid_move_examples": [
    [
      "INPUT:",
      "2 workers, no barracks",
      "OUTPUT:",
      "worker_2 builds barracks"
    ],
    [
      "INPUT:",
      "1 worker",
      "OUTPUT:",
      "train worker"
    ],
    [
      "INPUT:",
      "enemy barracks only",
      "OUTPUT:",
      "still build barracks"
    ],
    [
      "INPUT:",
      "5 workers, no barracks",
      "OUTPUT:",
      "worker_2 builds barracks (NOT train worker)"
    ]
  ]
}